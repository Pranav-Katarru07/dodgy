{
  "manifest_version": 3,
  "name": "dodgy",
  "version": "0.1.0",
  "description": "A mascot you must chase and guilt past to reach distracting sites. Don't kill dodgy.",
  "permissions": ["declarativeNetRequest", "storage", "alarms", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "dodgy"
  },
  "options_page": "src/settings/settings.html"
}
