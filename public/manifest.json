{
  "manifest_version": 3,
  "name": "dodgy",
  "version": "1.0.0",
  "description": "A guardian Pokémon defends your distracting sites — chase and guilt past it, or drain its HP and watch it faint. Don't let it faint.",
  "permissions": ["declarativeNetRequest", "storage", "alarms", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "dodgy"
  },
  "options_page": "src/settings/settings.html",
  "web_accessible_resources": [
    {
      "resources": ["src/gate/gate.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
